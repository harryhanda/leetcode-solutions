class Solution {
public:
    int rearrangeCharacters(string s, string target) {
        unordered_map<char, int> mpp;
        unordered_map<char, int> mpp2;
        int mini = INT_MAX;
        for (int i = 0; i < s.size(); i++) {
            mpp[s[i]]++;
        }
        for (int i = 0; i < target.size(); i++)
            mpp2[target[i]]++;

        for (int i = 0; i < target.size(); i++) {
            mini = min(mini, mpp[target[i]] / mpp2[target[i]]);
        }
        return mini;
    }
};
