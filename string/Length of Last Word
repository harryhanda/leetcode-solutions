class Solution {
public:
    int lengthOfLastWord(string s) {
      int size = s.size();
      int cnt = 0;;
      for(int i = size - 1; i >= 0; i--){
        
          if(cnt == 0 && s[i] == ' '){
            continue;
          }
          if(s[i] == ' '){
            break;
          }
          cnt += 1;
    }
    return cnt;
    }
};
