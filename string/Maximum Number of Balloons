class Solution {
public:
    int maxNumberOfBalloons(string text) {
        unordered_map<char, int> mpp;
        int mini = INT_MAX;
        string word = "balloon";
        for (int i = 0; i < text.size(); i++) {
            mpp[text[i]]++;
        }
        mpp['l'] /= 2;
        mpp['o'] /= 2;

        for(auto s1 : word){
            mini = min(mini, mpp[s1]);
        } 
        return mini;
    }
};
