class Solution {
public:
    string reverseStr(string s, int k) {
        int n = s.size();
        int l = 0;
        int r = 0;
     for(int i = 0; i < s.size() ; i += 2*k){
        l = i;
        r = min(i + k -1 , n - 1);
     while(l < r){
        swap(s[l],s[r]);
        l++;
        r--;      
    }}
    return s;
    }
};
